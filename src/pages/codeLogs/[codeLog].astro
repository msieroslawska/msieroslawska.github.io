---
import type { InferGetStaticPropsType } from "astro";
import { Breadcrumbs, BreadcrumbsItem } from 'accessible-astro-components'
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import DefaultLayout from '@layouts/DefaultLayout.astro'

import { client } from "../../lib/contentful";

export const getStaticPaths = async () => {
  return client.getPages();
}

export type CodeLogProps = InferGetStaticPropsType<typeof getStaticPaths>;

const {
  // id,
  learnedToday,
  otherResources,
  planForTheDay,
  resourcesList,
  // tags,
  title,
}: CodeLogProps = Astro.props;
---

<DefaultLayout title={title} description='asdf' url={title}>
  <div class="container">
    <div class="mt-12">
      <Breadcrumbs>
        <BreadcrumbsItem href="/" label="Home" />
        <BreadcrumbsItem href="/code-logs" label="Code Logs" />
        <BreadcrumbsItem currentPage={true} label={title} />
      </Breadcrumbs>
    </div>
  </div>
  <section class="my-12">
    <div class="container">
      <h1>{title}</h1><br />
    </div>
  </section>
  <section class="my-12">
    <div class="container">
        <h4>Plan for the day</h4>
        <article
          set:html={documentToHtmlString(planForTheDay.json)}
          class="leading-loose text-slate-200 text-justify"
        />
        <h4>Learned today</h4>
        <article
          set:html={documentToHtmlString(learnedToday.json)}
          class="leading-loose text-slate-200 text-justify"
        />
        { resourcesList && resourcesList.length > 0 && (
          <div>
          <h4>Resources list</h4>
          {resourcesList.map((resource) => (
            <ul>
              <li><a href={resource.url}>{resource.title}</a></li>
          </ul>
          ))}
          </div>
          )}
          { otherResources && otherResources.length > 0 && (
          <div>
          <h4>Other resources</h4>
          {otherResources.map((resource) => (
            <ul>
              <li><a href={resource.url}>{resource.title}</a></li>
          </ul>
          ))}
          </div>
          )}
  </section>
</DefaultLayout>

<style lang="scss">
  ul {
    display: grid;
    grid-template-columns: 1fr;
    grid-gap: 4rem;

    @media (min-width: 550px) {
      grid-template-columns: repeat(2, 1fr);
      grid-gap: 2rem;
    }

    @media (min-width: 950px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
