---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Card } from 'accessible-astro-components'

import { getCollection } from 'astro:content';
const articles = await getCollection('articles');
---

<DefaultLayout title="Articles">
  <section class="my-12">
    <div class="space-content container">
      <h1>Articles</h1>
      <p class="text-2xl">
        Articles were my way of learning a concept, by writing down the basics of it. This is a collection of all the articles I have written so far.
      </p>
    </div>
  </section>
  <section class="my-12">
    <div class="container">
      <!-- <p class="text-sm"><em>Post {page.start + 1} through {page.end + 1} of {page.total} total posts</em></p> -->
      <ul class="my-3">
        {
          articles.map((a) => (
            <li>
              <Card
                url={'/articles/' + a.slug}
                title={a.data.title}
                footer=""
              >
                {a.data.title}
              </Card>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  ul {
    display: grid;
    grid-template-columns: 1fr;
    grid-gap: 4rem;

    @media (min-width: 550px) {
      grid-template-columns: repeat(2, 1fr);
      grid-gap: 2rem;
    }

    @media (min-width: 950px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
